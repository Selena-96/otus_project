Процедура Получатель_УстановитьПараметрыПоУмолчанию(Consumer) Экспорт 
	
	otus_kafka.Получатель_УстановитьПараметрГлобальный(Consumer, "message.max.bytes", "10000");
	otus_kafka.Получатель_УстановитьПараметрГлобальный(Consumer, "socket.timeout.ms", "40000");
	otus_kafka.Получатель_УстановитьПараметрГлобальный(Consumer, "enable.auto.commit", "false");
	otus_kafka.Получатель_УстановитьПараметрГлобальный(Consumer, "auto.commit.interval.ms", "0");  
	
	otus_kafka.Получатель_УстановитьПараметрТопика(Consumer, "compression.codec", "lz4");
	otus_kafka.Получатель_УстановитьПараметрТопика(Consumer, "auto.offset.reset", "smallest");
	
КонецПроцедуры

Функция Получатель_УстановитьПараметрГлобальный(Consumer, Знач стрКлюч, Знач стрЗначение) Экспорт
	
	сткРезультат = Новый Структура();
	сткРезультат.Вставить("булУспешно", Ложь);
	сткРезультат.Вставить("стрОписаниеОшибки", "");	
		
	сткРезультат.булУспешно = Consumer.SetGlobalConf(стрКлюч, стрЗначение);
	Если сткРезультат.булУспешно <> Истина Тогда 
		сткРезультат.стрОписаниеОшибки = Consumer.ErrorDescription;
	КонецЕсли;
	
	Возврат сткРезультат;	
КонецФункции                                              

Функция Получатель_УстановитьПараметрТопика(Consumer, Знач стрКлюч, Знач стрЗначение) Экспорт
	
	сткРезультат = Новый Структура();
	сткРезультат.Вставить("булУспешно", Ложь);
	сткРезультат.Вставить("стрОписаниеОшибки", "");	
		
	сткРезультат.булУспешно = Consumer.SetTopicConf(стрКлюч, стрЗначение);
	Если сткРезультат.булУспешно <> Истина Тогда 
		сткРезультат.стрОписаниеОшибки = Consumer.ErrorDescription;
	КонецЕсли;
	
	Возврат сткРезультат;	
КонецФункции

Функция Получатель_Подписаться(Знач мТопики, Consumer) Экспорт
	
	сткРезультат = Новый Структура();
	сткРезультат.Вставить("Успешно", Ложь);
	сткРезультат.Вставить("стрОписаниеОшибки", "");	
	
	Результат = Consumer.ClearSubscribeList();
	Если Результат <> Истина Тогда
		сткРезультат.стрОписаниеОшибки = "Ошибка очистки списка топиков: " + Consumer.ErrorDescription;	
		Возврат сткРезультат;
	КонецЕсли;
	
	Для Каждого стрТопик Из мТопики Цикл 
		Результат = Consumer.AddTopicToSubscribeList(стрТопик);
		Если Результат <> Истина Тогда
			сткРезультат.стрОписаниеОшибки = "Ошибка добавления топика в список: " + Consumer.ErrorDescription;	
			Возврат сткРезультат;
		КонецЕсли;	
	КонецЦикла;
	
	Результат = Consumer.Subscribe();
	Если Результат <> Истина Тогда
		сткРезультат.стрОписаниеОшибки = "Ошибка подписания на топики: " + Consumer.ErrorDescription;	
		Возврат сткРезультат;
	КонецЕсли;
	
	сткРезультат.Успешно = Истина;	
	Возврат сткРезультат;	
КонецФункции

Функция ПрочитатьСообщение(Consumer) Экспорт

	ЧитатьСообщения = Истина;
	ЕстьОшибки = Ложь;
	
	тзДанные = Получатель_ПолучитьТаблицуСообщения();

	Пока ЧитатьСообщения Цикл
		чслЧтение = 1000;
		чслТаймаут = 1000;
		ЧитатьДД = Ложь;
		
		сткРезультат = Получатель_ЭкранироватьЗначениеСообщения(Consumer);
		Если Не сткРезультат.булУспешно Тогда
			стрОписаниеОшибки = сткРезультат.стрОписаниеОшибки;
			// обработка ошибки
			ЕстьОшибки = Истина;
			Прервать;
		КонецЕсли;	
		
		сткРезультат = Получатель_ЭкранироватьКлючСообщения(Consumer);
		Если Не сткРезультат.булУспешно Тогда
			стрОписаниеОшибки = сткРезультат.стрОписаниеОшибки;
			// обработка ошибки
			ЕстьОшибки = Истина;
			Прервать;
		КонецЕсли;	
		
		сткРезультат = Получатель_ЭкранироватьКлючиЗаголовков(Consumer);
		Если Не сткРезультат.булУспешно Тогда
			стрОписаниеОшибки = сткРезультат.стрОписаниеОшибки;
			// обработка ошибки
			ЕстьОшибки = Истина;
			Прервать;
		КонецЕсли;	
		
		сткРезультат = Получатель_ЭкранироватьЗначенияЗаголовков(Consumer);
		Если Не сткРезультат.булУспешно Тогда
			стрОписаниеОшибки = сткРезультат.стрОписаниеОшибки;
			// обработка ошибки
			ЕстьОшибки = Истина;
			Прервать;
		КонецЕсли;	

		
		//чНачало = ТекущаяУниверсальнаяДатаВМиллисекундах();
		сткРезультат = Получатель_ПрочитатьСписокСообщенийВПул(Consumer, чслЧтение, чслТаймаут, 10);
		Если Не сткРезультат.булУспешно Тогда
			стрОписаниеОшибки = сткРезультат.стрОписаниеОшибки;
			// обработка ошибки
			ЕстьОшибки = Истина;
			Прервать;
		КонецЕсли;	
		
		сткРезультат = Получатель_ПолучитьСообщенияИзПулаJSON(ЧитатьДД, Consumer);
		Если Не сткРезультат.булУспешно Тогда
			стрОписаниеОшибки = сткРезультат.стрОписаниеОшибки;
			// обработка ошибки
			ЕстьОшибки = Истина;
			Прервать;
		КонецЕсли;	
			
		//чОкончание = ТекущаяУниверсальнаяДатаВМиллисекундах();
		//Сообщить("Затрачено на получение: " + Строка(чОкончание - чНачало));

		сткРезультат = otus_ОбщегоНазначения.JSONВСтруктуру(сткРезультат.стрСообщения);
		Если Не сткРезультат.булУспешно Тогда
			стрОписаниеОшибки = сткРезультат.стрОписаниеОшибки;
			// обработка ошибки
			ЕстьОшибки = Истина;
			Прервать;
		КонецЕсли;	
		
		Если сткРезультат.масДанные.Количество() > 0 Тогда		
			сткРезультатФиксации = Получатель_ЗафиксироватьСмещения(Consumer);
			Если Не сткРезультатФиксации.булУспешно Тогда
				стрОписаниеОшибки = сткРезультат.стрОписаниеОшибки;
				// обработка ошибки
				ЕстьОшибки = Истина;
				Прервать;
			КонецЕсли;
		КонецЕсли;
		
		Если сткРезультат.масДанные.Количество() < 1000 Тогда 
			// больше нечего читать
			ЧитатьСообщения = Ложь;
		КонецЕсли;
				
		Для Каждого Элемент Из сткРезультат.масДанные Цикл
			
			стрДобавить = тзДанные.Добавить();
			ЗаполнитьЗначенияСвойств(стрДобавить, Элемент);	
			стрДобавить.headers = Получатель_ПолучитьТаблицуЗаголовки();
			
			Для Каждого СтрокаЗаголовок Из Элемент.Headers Цикл
				ЗаполнитьЗначенияСвойств(стрДобавить.headers.Добавить(), СтрокаЗаголовок);
			КонецЦикла;
		КонецЦикла;
		
	КонецЦикла;
	
	Если ЕстьОшибки Тогда
		Возврат Новый Структура("Успешно,Данные", Ложь, Неопределено);
	Иначе 
		Возврат Новый Структура("Успешно,Данные", Истина, тзДанные);
	КонецЕсли;
	
	
КонецФункции

Функция Получатель_ЭкранироватьКлючСообщения(Consumer, булЭкранировать = Истина) 
	
	сткРезультат = Новый Структура();
	сткРезультат.Вставить("булУспешно", Ложь);
	сткРезультат.Вставить("стрОписаниеОшибки", "");		
	
	Consumer.EscapeMessageKey = булЭкранировать;
	сткРезультат.булУспешно = Истина;
	Возврат сткРезультат;	
КонецФУнкции

