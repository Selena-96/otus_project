Функция Получатель_ПрочитатьСписокСообщенийВПул(Consumer, Знач чслКоличество, Знач чслТайимаутНаОдно, Знач ErrorCountToInterrupt = 1) 
	
	сткРезультат = Новый Структура();
	сткРезультат.Вставить("булУспешно", Ложь);
	сткРезультат.Вставить("булТаймаут", Ложь);
	сткРезультат.Вставить("FatalError", Ложь);

	сткРезультат.Вставить("чКоличествоПрочитано", 0);	
	сткРезультат.Вставить("стрОписаниеОшибки", "");
	
	Результат = Consumer.ConsumePool(чслТайимаутНаОдно, чслКоличество, ErrorCountToInterrupt);
	Если Результат <> 1 Тогда
		сткРезультат.стрОписаниеОшибки = Consumer.ErrorDescription;
	КонецЕсли;
	
	сткРезультат.булТаймаут = (сткРезультат.стрОписаниеОшибки = "Local: Timed out") ИЛИ (сткРезультат.стрОписаниеОшибки = "Timeout: Local: Timed out")
		ИЛИ (сткРезультат.стрОписаниеОшибки = "Local queue is full");
	сткРезультат.булУспешно = (сткРезультат.булТаймаут ИЛИ Результат = 1) И НЕ Consumer.FatalError;
	сткРезультат.FatalError = Consumer.FatalError;
	
	сткРезультат.чКоличествоПрочитано = Consumer.GetMessagePoolLength();		
	Возврат сткРезультат;	
КонецФункции

Функция Получатель_ПолучитьСообщенияИзПулаJSON(Знач булПолучатьBase64, Consumer) 
	
	сткРезультат = Новый Структура();
	сткРезультат.Вставить("булУспешно", Ложь);
	сткРезультат.Вставить("стрСообщения", Неопределено);
	сткРезультат.Вставить("стрОписаниеОшибки", "");	
		
	//Читаем из пула компоненты	
	сткРезультат.стрСообщения = Consumer.ReceiveJSONMessages(булПолучатьBase64);
	Если  сткРезультат.стрСообщения = Неопределено Тогда
		сткРезультат.стрОписаниеОшибки = Consumer.ErrorDescription;
		Возврат сткРезультат;
	КонецЕсли;	

	//Очищаем пул компоненты	
	Результат = Consumer.ClearMessagePool();
	Если Результат <> Истина Тогда
		сткРезультат.стрОписаниеОшибки = Consumer.ErrorDescription;
		Возврат сткРезультат;
	КонецЕсли;
	
	сткРезультат.булУспешно = Истина;
	Возврат сткРезультат;	
КонецФУнкции

Функция Получатель_ЗафиксироватьСмещения(Consumer) 
	
	сткРезультат = Новый Структура();
	сткРезультат.Вставить("булУспешно", Ложь);
	сткРезультат.Вставить("стрОписаниеОшибки", "");	
		
	сткРезультат.булУспешно = Consumer.Commit();
	Если сткРезультат.булУспешно <> Истина Тогда 
		сткРезультат.стрОписаниеОшибки = Consumer.ErrorDescription;
	КонецЕсли;
	
	Возврат сткРезультат;	
КонецФУнкции

