Функция Отправитель_Отправить(Producer) 
	
	сткРезультат = Новый Структура();
	сткРезультат.Вставить("Успешно", Ложь);
	сткРезультат.Вставить("стрОписаниеОшибки", "");
	
	сткРезультат.Успешно = Producer.Produce();	
	Если сткРезультат.Успешно <> Истина Тогда
		сткРезультат.стрОписаниеОшибки = Producer.ErrorDescription;
		Возврат сткРезультат;	
	КонецЕсли;

	сткРезультат.Успешно = Истина;
	Возврат сткРезультат;	
КонецФункции

Функция Отправитель_ВсеСообщенияДоставлены(Producer) 
	
	сткРезультат = Новый Структура();
	сткРезультат.Вставить("Успешно", Истина);
	сткРезультат.Вставить("булВсеСообщенияДоставлены", Ложь);

	сткРезультат.Вставить("стрОписаниеОшибки", "");	
	
	сткРезультат.булВсеСообщенияДоставлены = Producer.IsDelivered();
	Возврат сткРезультат;	
КонецФункции

Функция Отправитель_ПолучитьJSONОтчетОДоставке(Producer) 
	
	сткРезультат = Новый Структура();
	сткРезультат.Вставить("Успешно", Ложь);
	сткРезультат.Вставить("стрОтчетОДоставке", Неопределено);
	сткРезультат.Вставить("стрОписаниеОшибки", "");
	
	сткРезультат.стрОтчетОДоставке = Producer.GetJSONDeliveryReport();	
	Если сткРезультат.стрОтчетОДоставке = Неопределено Тогда
		сткРезультат.стрОписаниеОшибки = Producer.ErrorDescription;
		Возврат сткРезультат;	
	КонецЕсли;

	сткРезультат.Успешно = Истина;
	Возврат сткРезультат;	
КонецФункции

