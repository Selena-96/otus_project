
Функция ВыполнитьПодключениеВнешнейКомпоненты() Экспорт 
	Возврат ВыполнитьПодключениеВнешнейКомпонентыМакет();
КонецФункции

Функция ВыполнитьПодключениеВнешнейКомпонентыМакет()	
	
	сткРезультат = Новый Структура();
	сткРезультат.Вставить("Успешно", Ложь);
	сткРезультат.Вставить("стрОписаниеОшибки", "");     
	
	СистемнаяИнформация = Новый СистемнаяИнформация();
	Если СистемнаяИнформация.ТипПлатформы = ТипПлатформы.Windows_x86 Тогда	
		МакетКомпоненты = ПолучитьОбщийМакет("otus_librdkafka_win32");
	ИначеЕсли СистемнаяИнформация.ТипПлатформы = ТипПлатформы.Windows_x86_64 Тогда
		МакетКомпоненты = ПолучитьОбщийМакет("otus_librdkafka_win64");
	ИначеЕсли СистемнаяИнформация.ТипПлатформы = ТипПлатформы.Linux_x86 Тогда
		МакетКомпоненты = ПолучитьОбщийМакет("otus_librdkafka_linux32");	
	ИначеЕсли СистемнаяИнформация.ТипПлатформы = ТипПлатформы.Linux_x86_64 Тогда
		МакетКомпоненты = ПолучитьОбщийМакет("otus_librdkafka_linux64");		
	Иначе
		сткРезультат.стрОписаниеОшибки = "Не поддерживаемая архитектура платформы";
		Возврат сткРезультат;
	КонецЕсли;
	
	Попытка
		_РезультатПодключенияВнешнейКомпоненты = ПодключитьВнешнююКомпоненту(ПоместитьВоВременноеХранилище(МакетКомпоненты), "librdkafka", ТипВнешнейКомпоненты.Native);
		Если НЕ _РезультатПодключенияВнешнейКомпоненты Тогда
			сткРезультат.стрОписаниеОшибки = "Ошибка подключения внешней компоненты";
			Возврат сткРезультат;
		КонецЕсли;
	Исключение
		сткРезультат.стрОписаниеОшибки = ОписаниеОшибки();
		Возврат сткРезультат;
	КонецПопытки;
	
	сткРезультат.Успешно = Истина;
	
	Возврат сткРезультат;
КонецФункции   

#Область Отправка

Функция СоздатьОтправителя() Экспорт
	
	сткРезультат = Новый Структура();
	сткРезультат.Вставить("Успешно", Ложь);
	сткРезультат.Вставить("стрОписаниеОшибки", "");
	сткРезультат.Вставить("Producer", Неопределено);
	
	Попытка
		 сткРезультат.Producer = Новый("AddIn.librdkafka.KafkaProducer");
		 сткРезультат.Успешно = Истина;
		 Возврат сткРезультат;
	Исключение
	КонецПопытки;
	
	сткРезультатПодключения = ВыполнитьПодключениеВнешнейКомпоненты();
	Если Не сткРезультатПодключения.Успешно Тогда
		сткРезультат.стрОписаниеОшибки = сткРезультатПодключения.стрОписаниеОшибки;
		Возврат сткРезультат;	 
	КонецЕсли;
	 	 
	Попытка
		 сткРезультат.Producer = Новый("AddIn.librdkafka.KafkaProducer");
	Исключение
		сткРезультат.стрОписаниеОшибки = ОписаниеОшибки();
		Возврат сткРезультат;
	КонецПопытки;
	
	сткРезультат.Успешно = Истина;
	Возврат сткРезультат;
КонецФункции   

Функция Отправитель_ЗагрузитьСообщенияИзJSONВСписокНаОтправку(Знач стрJSON, Producer) Экспорт
	
	сткРезультат = Новый Структура();
	сткРезультат.Вставить("Успешно", Ложь);
	сткРезультат.Вставить("стрОписаниеОшибки", "");
	
	сткРезультат.Успешно = Producer.SetJSONMessageList(стрJSON);
	Если сткРезультат.Успешно <> Истина Тогда 
		сткРезультат.стрОписаниеОшибки = Producer.ErrorDescription;
	КонецЕсли;

	Возврат сткРезультат;	
КонецФункции 

